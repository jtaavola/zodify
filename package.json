{
  "name": "zodify-json",
  "version": "0.1.0",
  "description": "Convert sample JSON responses into Zod schemas.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jtaavola/zodify.git"
  },
  "keywords": ["zod", "json", "schema", "cli", "generator", "typescript"],
  "files": ["dist", "README.md", "LICENSE"],
  "type": "module",
  "bin": {
    "zodify": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "check": "biome check",
    "fix": "biome check --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2"
  }
}
